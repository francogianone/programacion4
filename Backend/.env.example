# ─── Backend — Variables de entorno ───────────────────────────────────────────
# Copia este archivo como .env y completa los valores reales
# cp .env.example .env

# Puerto en que corre el servidor Express
PORT=3000

# URI de conexión a MongoDB Atlas (reemplazá con tu propia cadena de conexión)
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Clave secreta para firmar los tokens JWT (usá una cadena larga y aleatoria)
JWT_SECRET=tu_clave_secreta_muy_larga_y_aleatoria

# Cuenta de Gmail desde la que se envían los correos (recuperación de contraseña y contacto)
GMAIL_USER=tu_correo@gmail.com

# Contraseña de aplicación de Google (generala en: Cuenta de Google → Seguridad → Contraseñas de aplicaciones)
GMAIL_PASS=xxxx xxxx xxxx xxxx

# URL del frontend — usada en links de recuperación de contraseña y como origen CORS extra.
# Podés poner varias URLs separadas por coma (ej: para staging + producción).
FRONTEND_URL=http://localhost:5173
